{
  "version": 2,
  "rewrites": [
    { "source": "/api/likes/:slug", "destination": "/api/app?path=api/likes/:slug" },
    { "source": "/api/likes", "destination": "/api/app?path=api/likes" },
    { "source": "/palette/:slug", "destination": "/api/app?path=palette/:slug" },
    { "source": "/category/:category", "destination": "/api/app?path=category/:category" },
    { "source": "/sitemap.xml", "destination": "/api/app?path=sitemap.xml" },
    { "source": "/", "destination": "/api/app?path=" }
  ]
}
